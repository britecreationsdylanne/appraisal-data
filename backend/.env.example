# Copy to backend/.env and adjust as needed.

# "local" = synthetic demo (creates + seeds tables). "production" = appraisal DB is
# READ-ONLY (no create/alter/seed against it).
APP_ENV=local

# Appraisal database (READ-ONLY in production). Local demo uses the Docker Postgres.
DATABASE_URL=postgresql+psycopg2://appraisal:appraisal@localhost:5436/appraisal_research

# App database (read/write: saved templates, history, saved items).
# Leave blank locally to reuse DATABASE_URL; set to a separate instance in production.
APP_DATABASE_URL=

# Anthropic — OPTIONAL for local dev.
# If unset, the "souls" run in deterministic fallback mode (still grounded in real stats).
ANTHROPIC_API_KEY=

# Model IDs per tier (model-migration skill: frontier / standard / economy)
MODEL_FRONTIER=claude-fable-5
MODEL_STANDARD=claude-sonnet-4-6
MODEL_ECONOMY=claude-haiku-4-5-20251001

# Decorative/editorial image generation ONLY (hero shots, backgrounds).
# Data charts are always rendered deterministically and never use this.
OPENAI_API_KEY=
MODEL_IMAGE=gpt-image-2

# Synthetic seed
SEED_ROWS=60000
SEED_START_YEAR=2019
SEED_END_YEAR=2025
